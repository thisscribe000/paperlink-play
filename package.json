{
  "name": "paperlink-play",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/api",
    "apps/bot",
    "apps/miniapp"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:bot": "npm --workspace apps/bot run dev",
    "dev:miniapp": "npm --workspace apps/miniapp run dev",
    "build:api": "npm --workspace apps/api run build",
    "build:bot": "npm --workspace apps/bot run build",
    "build:miniapp": "npm --workspace apps/miniapp run build"
  }
}